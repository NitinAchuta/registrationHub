# Clerk — create an application at https://dashboard.clerk.com
# Copy this file to `.env.local` and fill in values (`.env` is gitignored; use Vercel → Settings → Environment Variables for deploys).
#
# Windows / campus VPN / antivirus HTTPS scan: if Clerk logs
# UNABLE_TO_VERIFY_LEAF_SIGNATURE or an infinite ?__clerk_handshake redirect loop,
# `npm run dev` already passes --use-system-ca (see package.json). Or set:
# NODE_OPTIONS=--use-system-ca
#
# Same TLS issue can break the **Vercel CLI** (`vercel deploy`). Fix:
# PowerShell:  $env:NODE_OPTIONS="--use-system-ca"; vercel deploy --prod
# Or use:      npm run deploy:prod   (runs local Vercel CLI with --use-system-ca)

# Required
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional — URLs for hosted sign-in/up pages (defaults often work with modal + middleware)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Enable Google OAuth in Clerk Dashboard: User & Authentication → Social Connections → Google

# Google Sheets (server-only — never use NEXT_PUBLIC_ for these)
# Share the spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as Editor (read + write phone column D and notes V:ZZ).
# GOOGLE_PRIVATE_KEY uses escaped newlines in JSON; the server replaces \\n with real newlines.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_SHEET_ID=
# Optional — tab name if not literally `Export`
# GOOGLE_SHEET_EXPORTS_TAB=Export
# Optional — credits ledger tab (columns A–F: Company Name, Source Row Number, Amount, Reason, Created At, Created By)
# GOOGLE_SHEET_CREDITS_TAB=Credits
# Optional — Company Enrichment tab (columns A–O; populated via POST /api/enrichment/run)
# GOOGLE_SHEET_ENRICHMENT_TAB=Company Enrichment

# Local historical profiles (server-only read via /api/company-profiles)
# Place workbook at: data/MASTER - Company Profiles.xlsx
# Worksheet: Master Company Profile (fallback filename: MASTER - Company Profiles(2).xlsx)

# Financial Modeling Prep (server-only — enrichment uses stable/profile + employee-count endpoints)
# SEC_USER_AGENT is sent as User-Agent on outbound enrichment HTTP requests (recommended).
# FMP_API_KEY=
# SEC_USER_AGENT=
